{% extends 'base.html.twig' %}

{% block title %}{{ kind == 'removed' ? 'Signature removed' : 'Link not found' }} · OIATC{% endblock %}
{% block description %}Petition signature management.{% endblock %}
{% block robots %}noindex,nofollow{% endblock %}
{% block body_class %}route-petition-result{% endblock %}

{% block head_styles %}
  <style>
    .pet-result { max-width: 640px; margin: 0 auto; padding: var(--gap-8) var(--gap-5) var(--gap-9); }
    .pet-result h1 { font-family: var(--font-serif); font-weight: 400; font-size: clamp(26px, 4vw, 36px); line-height: 1.15; margin: 0 0 var(--gap-3); }
    .pet-result p { color: var(--ink-2); margin: 0 0 var(--gap-4); }
    .pet-result a.back { color: var(--accent-deep); }
  </style>
{% endblock %}

{% block content %}
<div class="pet-result">
  {% if kind == 'removed' %}
    <p class="eyebrow">OIATC · Petition</p>
    <h1>Your signature has been removed.</h1>
    <p>It is no longer counted and will not be shared with anyone. Miigwech for letting us know{% if campaign %}, and for considering {{ campaign.title }}{% endif %}.</p>
    <p>If you removed it by mistake, you can add your voice again anytime.</p>
  {% else %}
    <p class="eyebrow">OIATC · Petition</p>
    <h1>That link didn't work.</h1>
    <p>The remove link may have already been used, or it may be incomplete. If you would like your signature removed and this link will not work, write to <a href="mailto:jonesrussell42@gmail.com">jonesrussell42@gmail.com</a> and it will be taken care of.</p>
  {% endif %}
  <p><a class="back" href="/">&larr; Back to oiatc.ca</a></p>
</div>
{% endblock %}
