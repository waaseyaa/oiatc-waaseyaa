{% extends 'news/_layout.html.twig' %}

{% block title %}{{ post.title }} · OIATC News{% endblock %}
{% block description %}{{ post.summary }}{% endblock %}
{% block head_extra %}<link rel="canonical" href="https://oiatc.ca/news/{{ post.slug }}">{% endblock %}

{% block content %}
  <p class="backnav"><a href="/news">← All news</a></p>

  <article>
    <span class="post-date">{{ post.published_at|date('F j, Y') }}</span>
    <h1>{{ post.title }}</h1>

    <div class="post-body">{{ post.body|raw }}</div>

    {% set position_slugs = ['prescribeit'] %}
    {% set is_position = post.related_explainer in position_slugs %}
    <a class="explainer-cta" href="{{ (is_position ? '/positions/' : '/explainers/') ~ post.related_explainer }}">
      <span class="explainer-cta__k">{{ is_position ? 'Read the OIATC position' : 'Read the full explainer' }}</span>
      <span class="explainer-cta__t">{{ post.related_explainer|replace({'-': ' '})|title }} →</span>
    </a>
  </article>
{% endblock %}
