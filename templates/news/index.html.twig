{% extends 'base.html.twig' %}

{% block title %}News · OIATC{% endblock %}
{% block description %}Time-stamped updates from OIATC, newest first.{% endblock %}
{% block body_class %}route-news{% endblock %}
{% block canonical_url %}https://oiatc.ca/news{% endblock %}
{% block topnav %}<a href="/">&larr; Home</a>{% endblock %}

{% block head_styles %}
  <link rel="alternate" type="application/rss+xml" title="OIATC News" href="https://oiatc.ca/news/rss.xml">
  <style>
    /* News index on the site shell (base.html.twig + site.css tokens), so it
       follows the light/dark theme. Scoped .news-*. */
    .news-wrap { max-width: 820px; margin: 0 auto; padding: var(--gap-7) var(--gap-5) var(--gap-9); }
    .news-cover { padding-bottom: var(--gap-5); border-bottom: 1px solid var(--rule); }
    .news-wrap h1 { font-family: var(--font-serif); font-weight: 400; font-size: clamp(30px, 5vw, 44px); line-height: 1.1; letter-spacing: -0.01em; margin: var(--gap-3) 0; }
    .news-lede { font-family: var(--font-serif); font-size: clamp(18px, 1.6vw, 21px); line-height: 1.5; color: var(--ink-2); margin: 0; max-width: 60ch; }
    .news-rss { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; margin: var(--gap-4) 0 0; }
    .news-rss a { color: var(--accent-deep); text-decoration: none; }

    .news-filter { display: flex; flex-wrap: wrap; gap: 8px; margin: var(--gap-5) 0 0; font-family: var(--font-sans); }
    .news-filter a { font-size: 12px; font-weight: 600; letter-spacing: 0.04em; padding: 6px 13px; border: 1px solid var(--rule); border-radius: 999px; color: var(--ink-3); text-decoration: none; }
    .news-filter a:hover { border-color: var(--accent-soft); color: var(--accent-deep); }
    .news-filter a.is-active { background: var(--accent); border-color: var(--accent); color: var(--paper); }

    .news-list { list-style: none; padding: 0; margin: var(--gap-4) 0 0; }
    .news-item { padding: 26px 0; border-bottom: 1px solid var(--rule); }
    .news-item:last-child { border-bottom: none; }
    .news-date { font-family: var(--font-mono); font-size: 12px; color: var(--accent-deep); letter-spacing: 0.04em; font-variant-numeric: tabular-nums; }
    .news-title { font-family: var(--font-serif); font-size: 24px; line-height: 1.25; font-weight: 500; margin: 6px 0 8px; }
    .news-title a { color: var(--ink); text-decoration: none; }
    .news-title a:hover { color: var(--accent-deep); }
    .news-summary { font-size: 16px; line-height: 1.6; color: var(--ink-2); margin: 0 0 10px; max-width: 70ch; }
    .news-tag { font-family: var(--font-sans); font-size: 12.5px; color: var(--ink-3); }
    .news-tag a { color: var(--accent-deep); text-decoration: none; }
    .news-empty { color: var(--ink-3); font-style: italic; padding: 32px 0; }
  </style>
{% endblock %}

{% block content %}
<div class="news-wrap">
  <section class="news-cover">
    <p class="eyebrow">OIATC · News</p>
    <h1>News</h1>
    <p class="news-lede">Time-stamped updates from OIATC, newest first.</p>
    <p class="news-rss"><a href="/news/rss.xml">Subscribe via RSS &rarr;</a></p>
  </section>

  {% if explainers|length > 1 or active_explainer %}
    <nav class="news-filter" aria-label="Filter by topic">
      <a href="/news"{% if not active_explainer %} class="is-active"{% endif %}>All ({{ total }})</a>
      {% for e in explainers %}
        <a href="/news?explainer={{ e.slug }}"{% if active_explainer == e.slug %} class="is-active"{% endif %}>{{ e.slug|replace({'-': ' '})|title }} ({{ e.count }})</a>
      {% endfor %}
    </nav>
  {% endif %}

  <ul class="news-list">
    {% for post in posts %}
      <li class="news-item">
        <span class="news-date">{{ post.published_at|date('F j, Y') }}</span>
        <h2 class="news-title"><a href="/news/{{ post.slug }}">{{ post.title }}</a></h2>
        <p class="news-summary">{{ post.summary }}{% if post.body|length > 200 %}…{% endif %}</p>
        {% if post.related_explainer in ['anokii'] %}
          {% set rel_href = '/' ~ post.related_explainer %}
        {% elseif post.related_explainer in ['prescribeit', 'counter-disinformation'] %}
          {% set rel_href = '/positions/' ~ post.related_explainer %}
        {% elseif post.related_explainer in ['sagamok-portal'] %}
          {% set rel_href = '/disclosure/' ~ post.related_explainer %}
        {% else %}
          {% set rel_href = '/explainers/' ~ post.related_explainer %}
        {% endif %}
        <span class="news-tag">On: <a href="{{ rel_href }}">{{ post.related_explainer|replace({'-': ' '})|title }}</a></span>
      </li>
    {% else %}
      <li class="news-empty">No posts yet.</li>
    {% endfor %}
  </ul>
</div>
{% endblock %}
