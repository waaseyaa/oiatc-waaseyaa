{% block head_styles %}{% include 'partials/funder-styles.html.twig' %}{% endblock %}

{% block content %}
    <section class="masthead">
      <div class="shell">
        <div>
          <div class="eyebrow">Council</div>
          <h1 class="display">A council of two,<br>improving the systems<br>that serve First Nations.</h1>
        </div>
        <div>
          <p class="lede">We author governance for Indigenous-led digital decisions and run four programs that put it into use. Everything on this site is shipped and dated.</p>
          <dl class="fund-facts">
            <dt>Status</dt><dd>Incorporating, not-for-profit</dd>
            <dt>Programs</dt><dd>4, all with shipped work</dd>
            <dt>Funds held</dt><dd>Under trusteeship arrangements named on the <a href="/support">Support page</a></dd>
          </dl>
        </div>
      </div>
    </section>

    <section class="sec" id="programs">
      <div class="shell">
        <div class="sec__head reveal">
          <div><div class="sec__num">01 · Programs</div></div>
          <div>
            <h2 class="sec__title">Four programs. One premise.</h2>
            <p class="sec__intro">The systems meant to serve First Nations are rarely chosen by them. Each program puts that right in a different place. All four have shipped work.</p>
          </div>
        </div>
        <div class="fund-cards reveal">
          <article class="fund-card fund-card--flag">
            <div class="fund-card__k"><span>Language</span><span class="fund-card__badge">Flagship · live</span></div>
            <h3><a href="/programs/anishinaabemowin">Anishinaabemowin</a></h3>
            <p>Language revitalization with consent infrastructure: Elder corpus, lesson app, games, the doll, story nights.</p>
            <a class="fund-card__unlock" href="/programs/anishinaabemowin">$25k pilots the doll batch and a season of story nights &rarr;</a>
          </article>
          <article class="fund-card">
            <div class="fund-card__k"><span>Infrastructure</span></div>
            <h3><a href="/programs/anokii">Anokii</a></h3>
            <p>Nation-governed community platforms on Waaseyaa. Two vantages live, with a regional coverage plan ready to fund.</p>
            <a class="fund-card__unlock" href="/programs/anokii">Regional rollout, Sault to Manitoulin &rarr;</a>
          </article>
          <article class="fund-card">
            <div class="fund-card__k"><span>Knowledge</span></div>
            <h3><a href="/programs/community-knowledge">Community knowledge</a></h3>
            <p>Plain-language explainers members actually use: treaty annuities, the solar project, where your data lives.</p>
            <a class="fund-card__unlock" href="/programs/community-knowledge">Cited by local press &rarr;</a>
          </article>
          <article class="fund-card">
            <div class="fund-card__k"><span>Transparency</span></div>
            <h3><a href="/programs/transparency">Member resources</a></h3>
            <p>Helping members see how their governments and systems work: org explainers, records requests, responsible disclosure.</p>
            <a class="fund-card__unlock" href="/programs/transparency">What you can ask for, and how &rarr;</a>
          </article>
        </div>
      </div>
    </section>

    <section class="sec" id="proof">
      <div class="shell">
        <div class="sec__head reveal">
          <div><div class="sec__num">02 · Proof, not slideware</div></div>
          <div>
            <h2 class="sec__title">What exists today.</h2>
          </div>
        </div>
        <div class="fund-proof reveal">
          <div><div class="fund-proof__n">21,721</div><div class="fund-proof__l">dictionary entries preserved</div></div>
          <div><div class="fund-proof__n">20+</div><div class="fund-proof__l">pages shipped and dated</div></div>
          <div><div class="fund-proof__n">2</div><div class="fund-proof__l">platforms in active build</div></div>
          <div><div class="fund-proof__n">1st</div><div class="fund-proof__l">party analytics, no ad-tech</div></div>
        </div>
      </div>
    </section>

    <section class="sec sec--statement" id="theory">
      <div class="shell">
        <div class="sec__head reveal">
          <div><div class="sec__num">03 · Theory of change</div></div>
          <div>
            <h2 class="sec__title">When communities choose and govern their digital systems, the systems fit. When the systems fit, services and language outcomes improve. We exist to make the first part true.</h2>
          </div>
        </div>
      </div>
    </section>

    <section class="sec" id="support">
      <div class="shell">
        <div class="sec__head reveal">
          <div><div class="sec__num">04 · Support</div></div>
          <div>
            <h2 class="sec__title">Fund shipped work.</h2>
          </div>
        </div>
        <div class="fund-support reveal">
          <div>
            <p class="body body--wide">We are early and honest about it: incorporating now, funds held under named trusteeship until then. Each program page says exactly what the next dollar unlocks.</p>
          </div>
          <div>
            <a class="btn btn--primary" href="/support">Partner with OIATC &rarr;</a>
            <div class="fund-support__also">Also seeking: an Elder for the council, two arm's-length directors, and a first partner Nation.</div>
          </div>
        </div>
      </div>
    </section>

    <section class="sec" id="council">
      <div class="shell">
        <div class="sec__head reveal">
          <div><div class="sec__num">05 · Council members</div></div>
          <div>
            <h2 class="sec__title">Two seats, held with care.</h2>
            <p class="sec__intro">The council today is deliberately small. Growth is gated on fit, not urgency. Full profiles live on the <a class="link" href="/about">About page</a>.</p>
          </div>
        </div>
        <div class="grid-2 reveal">
          <article class="card">
            <div class="card__eyebrow">Council member</div>
            <h3>Russell Jones</h3>
            <p class="card__meta">Ojibwe from Sagamok Anishnawbek &middot; Founder &middot; Full-stack developer</p>
            <p class="body">In 2023 Russell was contracted to implement a case-management system at a First Nations Child and Family Advocacy Unit, saw within weeks that it would not fit the community, and made the case for a Canadian-built alternative already in use at neighbouring Nations. The recommendation was shelved and the contract ended. OIATC is how that lesson becomes a practice.</p>
          </article>
          <article class="card">
            <div class="card__eyebrow">Council member</div>
            <h3><a class="link" href="https://web.net" target="_blank" rel="noopener">Web Networks</a></h3>
            <p class="card__meta">Est. 1987 &middot; One of Canada's first ISPs &middot; Non-profit worker co-op &middot; Canadian soil</p>
            <p class="body">A non-profit worker co-op whose clients have included the Legislative Assembly of Nunavut and Nunavut Public Library Services. Web Networks provides OIATC's hosting foundation and sits on the council as its second member.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="sec" id="contact" aria-labelledby="contact-heading">
      <div class="shell">
        <div class="sec__head reveal">
          <div><div class="sec__num">06 · Contact</div></div>
          <div>
            <h2 class="sec__title" id="contact-heading">jonesrussell42@gmail.com</h2>
            <p class="sec__intro">One seat is held by the founder. Writing to Russell is writing to OIATC.</p>
          </div>
        </div>
        <div class="actions reveal">
          <a class="btn btn--primary" href="mailto:jonesrussell42@gmail.com">Email Russell &rarr;</a>
          <a class="btn btn--secondary" href="/support">Partner with OIATC</a>
        </div>
      </div>
    </section>
{% endblock %}
