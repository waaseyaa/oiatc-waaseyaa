{% extends 'base.html.twig' %}

{% block title %}Ontario Indigenous AI &amp; Technology Council{% endblock %}
{% block description %}We author governance for Indigenous-led digital decisions and run four programs that put it into use: language, sovereign infrastructure, community knowledge, and member resources. Everything here is shipped and dated.{% endblock %}
{% block body_class %}route-home{% endblock %}

{# Canonical / og:* / twitter:* come from base defaults + /images/og/home.png.
   Home is a website root, not an article. #}
{% block og_type %}website{% endblock %}
{% block og_description %}We author governance for Indigenous-led digital decisions and run four programs that put it into use. Everything on this site is shipped and dated.{% endblock %}

