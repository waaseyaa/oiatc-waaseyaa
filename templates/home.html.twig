{% extends 'base.html.twig' %}

{% block title %}Ontario Indigenous AI &amp; Technology Council{% endblock %}
{% block description %}A council of two working to improve the digital systems that deliver services to First Nations. Governance framework, the Waaseyaa technical framework, and the Minoo community platform.{% endblock %}
{% block body_class %}route-home{% endblock %}

{# Canonical / og:* / twitter:* are provided by base.html.twig defaults using
   the page blocks above and the auto-rendered OG card at /images/og/home.png.
   Home is a website-type root, not an article — override og_type. The shorter
   og_description trims the framework/platform names so the social preview
   reads as a single hook. JSON-LD lives in its own block, separate from meta. #}
{% block og_type %}website{% endblock %}
{% block og_description %}A council of two working to improve the digital systems that deliver services to First Nations.{% endblock %}

