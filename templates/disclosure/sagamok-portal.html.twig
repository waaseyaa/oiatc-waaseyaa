      <line x1="20" y1="106" x2="560" y2="106" stroke="#243349" stroke-width="1"/>

      <text class="lblb" x="20" y="126">A search engine, an AI tool, or anything not a browser</text>
      <rect class="bx" x="20" y="138" width="158" height="46" rx="10"/>
