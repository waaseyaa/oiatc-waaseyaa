{#
  Reusable "Add your voice" petition card.

  Drop it at the bottom of any page with just a campaign slug:

      {% include 'partials/add-your-voice.html.twig' with { campaign_slug: 'sagamok-data-governance' } %}

  Optional overrides for server-side first paint (the card also hydrates itself
  from /api/petition/{slug}): headline, ask, recipient.

  Sovereignty: the form posts name + email only to OIATC's own backend
  (/api/petition/sign) on OIATC-controlled infrastructure. No third-party
  scripts, trackers, embeds, or CAPTCHA. Self-contained dark card with scoped
  .ayv-* styles, so it looks the same dropped into any explainer (warm or dark).
#}
<section class="ayv" data-ayv data-slug="{{ campaign_slug }}" aria-labelledby="ayv-h-{{ campaign_slug }}">
  <style>
    .ayv {
      --ayv-bg: oklch(0.20 0.012 240);
      --ayv-bg-2: oklch(0.25 0.014 240);
      --ayv-fg: oklch(0.96 0.005 80);
      --ayv-muted: oklch(0.72 0.01 240);
      --ayv-rule: oklch(0.36 0.014 240);
      --ayv-accent: oklch(0.72 0.13 55);
      --ayv-accent-ink: oklch(0.24 0.05 55);
      --ayv-serif: "Source Serif 4", Georgia, serif;
      --ayv-sans: "Inter", system-ui, sans-serif;
      --ayv-mono: "JetBrains Mono", ui-monospace, monospace;
      max-width: 720px;
      margin: 56px auto 0;
      background: var(--ayv-bg);
      color: var(--ayv-fg);
      border: 1px solid var(--ayv-rule);
      border-radius: 14px;
      padding: 28px 26px;
      font-family: var(--ayv-sans);
      font-size: 15px;
      line-height: 1.55;
    }
    .ayv * { box-sizing: border-box; }
    .ayv__eyebrow { font-family: var(--ayv-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ayv-accent); margin: 0 0 10px; }
    .ayv__h { font-family: var(--ayv-serif); font-size: clamp(24px, 3vw, 30px); line-height: 1.15; font-weight: 500; margin: 0 0 10px; color: #fff; }
    .ayv__ask { color: var(--ayv-fg); font-size: 16px; margin: 0 0 4px; }
    .ayv__recipient { color: var(--ayv-muted); font-size: 13.5px; margin: 0 0 16px; }
    .ayv__count { display: flex; align-items: baseline; gap: 8px; margin: 0 0 18px; padding: 12px 14px; background: var(--ayv-bg-2); border: 1px solid var(--ayv-rule); border-radius: 10px; }
    .ayv__count b { font-family: var(--ayv-sans); font-size: 24px; font-weight: 700; color: #fff; font-variant-numeric: tabular-nums; }
    .ayv__count span { color: var(--ayv-muted); font-size: 13.5px; }

    .ayv__field { margin: 0 0 14px; }
    .ayv__label { display: block; font-size: 13px; font-weight: 600; color: var(--ayv-fg); margin: 0 0 5px; }
    .ayv__input, .ayv__textarea {
      width: 100%; background: var(--ayv-bg-2); color: var(--ayv-fg);
      border: 1px solid var(--ayv-rule); border-radius: 8px; padding: 10px 12px;
      font: inherit;
    }
    .ayv__textarea { min-height: 72px; resize: vertical; }
    .ayv__input:focus, .ayv__textarea:focus { outline: 2px solid var(--ayv-accent); outline-offset: 1px; border-color: var(--ayv-accent); }

    .ayv__seg { display: inline-flex; border: 1px solid var(--ayv-rule); border-radius: 999px; overflow: hidden; }
    .ayv__seg label { padding: 8px 16px; font-size: 13.5px; cursor: pointer; color: var(--ayv-muted); }
    .ayv__seg input { position: absolute; opacity: 0; pointer-events: none; }
    .ayv__seg label:first-of-type { border-right: 1px solid var(--ayv-rule); }
    .ayv__seg input:checked + span { color: var(--ayv-accent-ink); }
    .ayv__seg label:has(input:checked) { background: var(--ayv-accent); color: var(--ayv-accent-ink); font-weight: 600; }

    .ayv__check { display: flex; gap: 10px; align-items: flex-start; margin: 0 0 12px; font-size: 13.5px; color: var(--ayv-fg); }
    .ayv__check input { margin-top: 3px; width: 16px; height: 16px; flex: none; accent-color: var(--ayv-accent); }

    /* Honeypot: kept in the DOM for bots, hidden from people and AT. */
    .ayv__hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }

    .ayv__submit { -webkit-appearance: none; appearance: none; border: none; cursor: pointer; background: var(--ayv-accent); color: var(--ayv-accent-ink); font-family: var(--ayv-sans); font-size: 15px; font-weight: 700; padding: 12px 22px; border-radius: 999px; }
    .ayv__submit:disabled { opacity: 0.6; cursor: default; }
    .ayv__msg { margin: 12px 0 0; font-size: 13.5px; min-height: 1em; }
    .ayv__msg.is-error { color: oklch(0.78 0.13 35); }
    .ayv__privacy { margin: 16px 0 0; padding-top: 14px; border-top: 1px solid var(--ayv-rule); font-size: 12.5px; color: var(--ayv-muted); line-height: 1.5; }
    .ayv__privacy a { color: var(--ayv-accent); }

    .ayv__done { display: none; }
    .ayv.is-done .ayv__form { display: none; }
    .ayv.is-done .ayv__done { display: block; }
    .ayv__done h3 { font-family: var(--ayv-serif); font-size: 22px; font-weight: 500; color: #fff; margin: 0 0 8px; }
    .ayv__done p { color: var(--ayv-fg); margin: 0 0 8px; }
    .ayv__remove { color: var(--ayv-muted); font-size: 12.5px; }
    .ayv__remove a { color: var(--ayv-accent); }
    @media (max-width: 620px) { .ayv { padding: 22px 18px; border-radius: 12px; } }
  </style>

  <p class="ayv__eyebrow">OIATC · Add your voice</p>
  <h2 class="ayv__h" id="ayv-h-{{ campaign_slug }}">{{ headline|default('Add your voice') }}</h2>
  {% if ask is defined %}<p class="ayv__ask" data-ayv-ask>{{ ask }}</p>{% else %}<p class="ayv__ask" data-ayv-ask></p>{% endif %}
  <p class="ayv__recipient" data-ayv-recipient>{% if recipient is defined %}To: {{ recipient }}{% endif %}</p>

  <div class="ayv__count" data-ayv-countbox hidden>
    <b data-ayv-count>0</b><span>people have added their voice</span>
  </div>

  <form class="ayv__form" data-ayv-form novalidate>
    <div class="ayv__hp" aria-hidden="true">
      <label>Leave this field empty<input type="text" name="website" tabindex="-1" autocomplete="off"></label>
    </div>

    <div class="ayv__field">
      <label class="ayv__label" for="ayv-name-{{ campaign_slug }}">Your name</label>
      <input class="ayv__input" id="ayv-name-{{ campaign_slug }}" name="name" type="text" autocomplete="name" maxlength="120" required>
    </div>

    <div class="ayv__field">
      <label class="ayv__label" for="ayv-email-{{ campaign_slug }}">Email</label>
      <input class="ayv__input" id="ayv-email-{{ campaign_slug }}" name="email" type="email" autocomplete="email" maxlength="255" required>
    </div>

    <div class="ayv__field">
      <span class="ayv__label">I am a…</span>
      {# Default to "Sagamok member" for Sagamok-related campaigns; a future
         non-Sagamok use can pass member_default: 'supporter' to the include. #}
      <span class="ayv__seg" role="radiogroup" aria-label="Member or supporter">
        <label><input type="radio" name="member_flag" value="member"{% if member_default|default('member') == 'member' %} checked{% endif %}><span>Sagamok member</span></label>
        <label><input type="radio" name="member_flag" value="supporter"{% if member_default|default('member') != 'member' %} checked{% endif %}><span>Supporter</span></label>
      </span>
    </div>

    <div class="ayv__field">
      <label class="ayv__label" for="ayv-comment-{{ campaign_slug }}">A comment (optional)</label>
      <textarea class="ayv__textarea" id="ayv-comment-{{ campaign_slug }}" name="comment" maxlength="500"></textarea>
    </div>

    <label class="ayv__check">
      <input type="checkbox" name="show_name_publicly" value="1">
      <span>You may show my name if supporters are listed publicly later.</span>
    </label>

    <label class="ayv__check">
      <input type="checkbox" name="consent" value="1" required>
      <span>I consent to OIATC storing my name and email for this petition. <strong>(required)</strong></span>
    </label>

    <button class="ayv__submit" type="submit" data-ayv-submit>Add your voice</button>
    <p class="ayv__msg" data-ayv-msg role="status" aria-live="polite"></p>
  </form>

  <div class="ayv__done" data-ayv-done aria-live="polite">
    <h3>Miigwech, your voice is added.</h3>
    <p data-ayv-donecount></p>
    <p class="ayv__remove" data-ayv-removewrap hidden>Changed your mind? <a href="#" data-ayv-remove>Remove my signature</a>. Keep this link private to you.</p>
  </div>

  <p class="ayv__privacy">
    Name and email only. Stored on Canadian, Indigenous-governed servers under OCAP. No band numbers, no trackers. Remove yours anytime.
    <a href="/petition/privacy">How your information is handled</a>.
  </p>
</section>

<script defer src="/js/add-your-voice.js"></script>
