{% extends 'base.html.twig' %}

{% block title %}Contact / Partner | OIATC{% endblock %}

{% block content %}
  <section class="page-header">
    <div class="eyebrow">Get in touch</div>
    <h1>Contact / Partner</h1>
    <p>OIATC is organizing its first public relationships across Nations, funders, researchers, collaborators, and prospective founding-circle advisors.</p>
  </section>

  <section class="section contact-grid">
    <article>
      <h3>Nations and communities</h3>
      <p>Start a conversation about governance, partnership, and community-grounded digital priorities.</p>
      <a class="button-secondary" href="mailto:jonesrussell42@gmail.com?subject=OIATC%20Nation%20or%20Community%20Inquiry">Email OIATC</a>
    </article>
    <article>
      <h3>Funders</h3>
      <p>Discuss grant fit, institutional readiness, and support for Indigenous-governed digital infrastructure.</p>
      <a class="button-secondary" href="mailto:jonesrussell42@gmail.com?subject=OIATC%20Funding%20Inquiry">Email funding desk</a>
    </article>
    <article>
      <h3>Researchers and institutional partners</h3>
      <p>Connect on governance research, policy work, technical collaboration, or public-interest partnership.</p>
      <a class="button-secondary" href="mailto:jonesrussell42@gmail.com?subject=OIATC%20Research%20or%20Institutional%20Partnership">Email partnerships</a>
    </article>
    <article>
      <h3>Founding-circle or advisory interest</h3>
      <p>Reach out if you want to support the founding structure with governance, legal, technical, or community leadership.</p>
      <a class="button-secondary" href="mailto:jonesrussell42@gmail.com?subject=OIATC%20Founding%20Circle%20Interest">Email founding circle</a>
    </article>
    <article>
      <h3>General inquiries</h3>
      <p>For anything that doesn't fit the categories above.</p>
      <a class="button-secondary" href="mailto:jonesrussell42@gmail.com?subject=OIATC%20General%20Inquiry">Email OIATC</a>
    </article>
  </section>
{% endblock %}
