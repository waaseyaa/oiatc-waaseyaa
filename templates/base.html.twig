<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Ontario Indigenous AI &amp; Technology Council{% endblock %}</title>
  <meta name="description" content="{% block description %}OIATC is building Indigenous digital sovereignty in Ontario through governance, training, research, and platform stewardship.{% endblock %}">
  <link rel="stylesheet" href="/css/site.css">
</head>
<body class="route-{{ path == '/' ? 'home' : path|trim('/')|replace({'/': '-'}) }}">
  <div class="site-shell">
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/">
          <span class="brand__mark">OIATC</span>
          <span class="brand__meta">
            <span class="brand__eyebrow">Ontario Indigenous AI &amp; Technology Council</span>
            <span class="brand__name">Indigenous digital sovereignty in Ontario</span>
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <div class="site-nav__group">
            <a href="/" {% if path == '/' %}aria-current="page"{% endif %}>Home</a>
            <a href="/about" {% if path == '/about' %}aria-current="page"{% endif %}>About</a>
            <a href="/waaseyaa" {% if path == '/waaseyaa' %}aria-current="page"{% endif %}>Waaseyaa</a>
            <a href="/minoo" {% if path == '/minoo' %}aria-current="page"{% endif %}>Minoo</a>
          </div>
          <div class="site-nav__group site-nav__group--secondary">
            <a href="/grants" {% if path == '/grants' %}aria-current="page"{% endif %}>Grants</a>
            <a class="site-nav__action" href="/contact" {% if path == '/contact' %}aria-current="page"{% endif %}>Contact</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__brand">
          <strong>Ontario Indigenous AI &amp; Technology Council</strong>
          <p>Governance, platform stewardship, training, and research rooted in Indigenous law, protocol, and continuity.</p>
        </div>
        <div class="site-footer__links">
          <a href="/about">About</a>
          <a href="/waaseyaa">Waaseyaa</a>
          <a href="/minoo">Minoo</a>
          <a href="/grants">Grants</a>
          <a href="/founding-charter">Charter</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
    </footer>
  </div>
</body>
</html>
