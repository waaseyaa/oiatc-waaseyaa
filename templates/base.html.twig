<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Ontario Indigenous AI &amp; Technology Council{% endblock %}</title>
  <meta name="description" content="{% block description %}OIATC is building Indigenous digital sovereignty in Ontario through governance, training, research, and platform stewardship.{% endblock %}">
  <meta property="og:title" content="{% block og_title %}Ontario Indigenous AI &amp; Technology Council{% endblock %}">
  <meta property="og:description" content="{% block og_description %}Indigenous digital sovereignty in Ontario through governance, training, research, and platform stewardship.{% endblock %}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://oiatc.waaseyaa.org{{ path }}">
  <meta property="og:image" content="{% block og_image %}https://oiatc.waaseyaa.org/images/og-default.png{% endblock %}">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="stylesheet" href="/css/site.css">
</head>
<body class="route-{{ path == '/' ? 'home' : path|trim('/')|replace({'/': '-'}) }}">
  <a class="skip-link" href="#main-content">Skip to content</a>
  <div class="site-shell">
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/">
          <span class="brand__mark">OIATC</span>
          <span class="brand__meta">
            <span class="brand__eyebrow">Ontario Indigenous AI &amp; Technology Council</span>
            <span class="brand__name">Indigenous digital sovereignty in Ontario</span>
          </span>
        </a>
        <button class="site-nav__toggle" aria-expanded="false" aria-controls="site-nav" aria-label="Menu">
          <span class="site-nav__toggle-bar"></span>
          <span class="site-nav__toggle-bar"></span>
          <span class="site-nav__toggle-bar"></span>
        </button>
        <nav class="site-nav" id="site-nav" aria-label="Primary">
          <div class="site-nav__group">
            <a href="/" {% if path == '/' %}aria-current="page"{% endif %}>Home</a>
            <a href="/about" {% if path == '/about' %}aria-current="page"{% endif %}>About</a>
            <a href="/waaseyaa" {% if path == '/waaseyaa' %}aria-current="page"{% endif %}>Waaseyaa</a>
            <a href="/minoo" {% if path == '/minoo' %}aria-current="page"{% endif %}>Minoo</a>
          </div>
          <div class="site-nav__group site-nav__group--secondary">
            <a href="/grants" {% if path == '/grants' %}aria-current="page"{% endif %}>Grants</a>
            <a class="site-nav__action" href="/contact" {% if path == '/contact' %}aria-current="page"{% endif %}>Contact</a>
          </div>
        </nav>
      </div>
    </header>

    <main id="main-content">
      {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__brand">
          <strong>Ontario Indigenous AI &amp; Technology Council</strong>
          <p>Governance, platform stewardship, training, and research rooted in Indigenous law, protocol, and continuity.</p>
        </div>
        <div class="site-footer__links">
          <a href="/about">About</a>
          <a href="/waaseyaa">Waaseyaa</a>
          <a href="/minoo">Minoo</a>
          <a href="/grants">Grants</a>
          <a href="/founding-charter">Charter</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
    </footer>
  </div>
    <script>
    (function() {
      var toggle = document.querySelector('.site-nav__toggle');
      var nav = document.getElementById('site-nav');
      if (!toggle || !nav) return;
      toggle.addEventListener('click', function() {
        var expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        nav.classList.toggle('is-open');
      });
      nav.addEventListener('click', function(e) {
        if (e.target.tagName === 'A') {
          toggle.setAttribute('aria-expanded', 'false');
          nav.classList.remove('is-open');
        }
      });
    })();
    </script>
</body>
</html>
