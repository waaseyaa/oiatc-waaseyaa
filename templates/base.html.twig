<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Ontario Indigenous AI &amp; Technology Council{% endblock %}</title>
  <meta name="description" content="{% block description %}A small council working to improve the digital systems that deliver services to First Nations.{% endblock %}">
  {# Sensible defaults for canonical / OG / Twitter tags.

     Pages override ONE LINE at a time — these are the canonical override
     blocks. Most pages need nothing here; the base auto-fills everything
     from {% block title %}, {% block description %}, and the per-page card
     auto-rendered by scripts/generate-og.js (computed in HomeController::socialContext).

     | Block            | What it controls                | Override example
     | ---------------- | ------------------------------- | ------------------------------------------------------
     | robots           | <meta robots>                   | {% block robots %}noindex,follow{% endblock %}
     | canonical_url    | canonical + og:url (mirrored)   | {% block canonical_url %}https://oiatc.ca/foo{% endblock %}
     | og_type          | og:type                         | {% block og_type %}website{% endblock %}
     | og_title         | og:title + twitter:title        | {% block og_title %}Short headline{% endblock %}
     | og_description   | og:description + twitter:desc   | {% block og_description %}Short social blurb.{% endblock %}
     | og_image         | og:image + twitter:image        | {% block og_image %}https://oiatc.ca/images/og-my-card.png{% endblock %}

     Whole-block override (skip ALL defaults) is still possible by re-declaring
     {% block head_meta %} entirely in the child. Avoid that for the common case. #}
  {% block head_meta %}
    <meta name="robots" content="{% block robots %}index,follow{% endblock %}">
    <link rel="canonical" href="{% block canonical_url %}{{ og_url|default('https://oiatc.ca') }}{% endblock %}">
    <meta property="og:site_name" content="Ontario Indigenous AI &amp; Technology Council">
    <meta property="og:locale" content="en_CA">
    <meta property="og:type" content="{% block og_type %}article{% endblock %}">
    <meta property="og:url" content="{{ block('canonical_url') }}">
    {# Decode &amp; (and a couple of common siblings) before Twig re-escapes for
       the attribute, otherwise titles like "OIATC &amp;" become "&amp;amp;". #}
    <meta property="og:title" content="{% block og_title %}{{ block('title')|replace({' · OIATC': '', ' — OIATC': '', '&amp;': '&', '&#039;': "'", '&quot;': '"'})|trim }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ block('description')|replace({'&amp;': '&', '&#039;': "'", '&quot;': '"'})|trim }}{% endblock %}">
    <meta property="og:image" content="{% block og_image %}{{ og_image_url|default('https://oiatc.ca/images/og-default.png') }}{% endblock %}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ block('og_title') }}">
    <meta name="twitter:description" content="{{ block('og_description') }}">
    <meta name="twitter:image" content="{{ block('og_image') }}">
  {% endblock %}
  {# Optional structured-data block for schema.org JSON-LD. Pages append rich
     data here without having to redeclare head_meta. #}
  {% block schema_jsonld %}{% endblock %}
  <meta name="theme-color" content="#f8f5ef" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#0d1420" media="(prefers-color-scheme: dark)">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;1,8..60,300;1,8..60,400&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap">
  <link rel="stylesheet" href="/css/site.css">
  <script defer src="/js/oiatc-analytics.js?v=3"></script>
  {% block head_styles %}{% endblock %}
</head>
<body data-theme="light" data-grain="off" data-density="comfortable" class="{% block body_class %}{% endblock %}">
  <a class="skip-link" href="#main-content">Skip to content</a>

  <header class="top">
    <div class="top__inner">
      <a class="brand" href="/">
        <span class="brand__mark">OIATC</span>
        <span class="brand__title">Ontario Indigenous AI &amp; Technology Council</span>
      </a>
      <div class="top__meta">
        {% block topnav %}<a href="/programs">Programs</a> <a href="/news">News</a> <a href="/about">About</a> <a href="/support">Support</a>{% endblock %}
        <button class="theme-toggle" type="button" aria-label="Toggle theme" data-theme-toggle>Dark</button>
      </div>
    </div>
  </header>

  <main id="main-content">
    {% block content %}{% endblock %}
  </main>

  {% block footer %}
  <footer class="site-foot">
    <div class="shell">
      <span>Ontario Indigenous AI &amp; Technology Council</span>
      <span>
        <a href="/anishinaabemowin">Anishinaabemowin</a>
        &nbsp;·&nbsp;
        <a href="/programs/anokii">Anokii</a>
        &nbsp;·&nbsp;
        <a href="/programs/community-knowledge">Community knowledge</a>
        &nbsp;·&nbsp;
        <a href="/programs/member-resources">Member resources</a>
      </span>
      <span>
        <a href="/about">About</a>
        &nbsp;·&nbsp;
        <a href="/support">Support</a>
        &nbsp;·&nbsp;
        <a href="https://waaseyaa.org" target="_blank" rel="noopener">Waaseyaa</a>
        &nbsp;·&nbsp;
        <a href="https://web.net" target="_blank" rel="noopener">Web Networks</a>
        &nbsp;·&nbsp;
        <a href="mailto:jonesrussell42@gmail.com">Email</a>
      </span>
    </div>
  </footer>
  {% endblock %}

  <script>
    (function () {
      var body = document.body;
      var btn = document.querySelector('[data-theme-toggle]');
      var stored = null;
      try { stored = localStorage.getItem('oiatc-theme'); } catch (e) {}
      if (stored === 'dark' || stored === 'light') {
        body.setAttribute('data-theme', stored);
      }
      function syncLabel() {
        if (!btn) return;
        btn.textContent = body.getAttribute('data-theme') === 'dark' ? 'Light' : 'Dark';
      }
      syncLabel();
      if (btn) {
        btn.addEventListener('click', function () {
          var next = body.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          body.setAttribute('data-theme', next);
          try { localStorage.setItem('oiatc-theme', next); } catch (e) {}
          syncLabel();
        });
      }

      var els = document.querySelectorAll('.reveal');
      if (!els.length || !window.IntersectionObserver) {
        els.forEach(function (el) { el.classList.add('is-revealed'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      els.forEach(function (el) { io.observe(el); });
    })();
  </script>
  {% block scripts_extra %}{% endblock %}
</body>
</html>
