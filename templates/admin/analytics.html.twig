<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Analytics · OIATC</title>
  <meta name="robots" content="noindex, nofollow">
  <meta name="theme-color" content="#f8f5ef" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#0d1420" media="(prefers-color-scheme: dark)">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap">
  <style>
    :root {
      --bg: #f8f5ef;
      --surface: #fffefb;
      --ink: #0d1420;
      --ink-soft: #2b3340;
      --ink-mute: #5b6473;
      --rule: #d9d2c2;
      --rule-soft: #ebe6d8;
      --accent: #6a3a1f;
      --accent-soft: #b88a5a;
      --highlight: #f1ebd6;
      --serif: "Source Serif 4", Georgia, serif;
      --sans: "Inter", system-ui, sans-serif;
      --mono: "JetBrains Mono", ui-monospace, monospace;
      --content: 880px;
      --gap-1: 4px;
      --gap-2: 8px;
      --gap-3: 12px;
      --gap-4: 20px;
      --gap-5: 32px;
      --gap-6: 56px;
    }
    * { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font-family: var(--serif);
      font-size: 18px;
      line-height: 1.65;
      font-feature-settings: "ss01", "ss02";
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }
    a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent-soft); }
    a:hover { color: var(--ink); }

    /* Header bar */
    .top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 18px 32px;
      max-width: var(--content);
      margin: 0 auto;
      border-bottom: 1px solid var(--rule);
      font-family: var(--sans);
      font-size: 12px;
      color: var(--ink-mute);
      letter-spacing: 0.04em;
      gap: 16px;
      flex-wrap: wrap;
    }
    .top__brand {
      font-weight: 600;
      color: var(--ink);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .top__brand a { color: var(--ink); border-bottom: none; }
    .top__brand a:hover { color: var(--accent); }
    .top__meta { font-family: var(--mono); font-variant-numeric: tabular-nums; }

    /* Page */
    .page {
      max-width: var(--content);
      margin: 0 auto;
      padding: 40px 28px 72px;
    }
    @media (min-width: 700px) {
      .page { padding: 48px 40px 96px; }
    }

    .eyebrow {
      font-family: var(--sans);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 16px;
    }

    /* Sections */
    section { padding: 36px 0; border-bottom: 1px solid var(--rule-soft); }
    section:last-of-type { border-bottom: none; }
    h2 {
      font-family: var(--sans);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 var(--gap-4);
    }

    /* Date-range form */
    .range-form {
      display: flex;
      align-items: flex-end;
      gap: var(--gap-3);
      flex-wrap: wrap;
    }
    .range-form .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .range-form label {
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-mute);
    }
    .range-form input[type="date"] {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--ink);
      background: var(--surface);
      border: 1px solid var(--rule);
      border-radius: 4px;
      padding: 8px 10px;
      font-variant-numeric: tabular-nums;
    }
    .range-form input[type="date"]:focus {
      outline: none;
      border-color: var(--accent-soft);
    }
    .range-form button {
      font-family: var(--sans);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--surface);
      background: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 4px;
      padding: 9px 20px;
      cursor: pointer;
    }
    .range-form button:hover { background: var(--ink); border-color: var(--ink); }

    /* Totals */
    .totals {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--gap-4);
    }
    .stat {
      background: var(--surface);
      border: 1px solid var(--rule);
      border-radius: 4px;
      padding: 24px 26px;
    }
    .stat__label {
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-mute);
      margin: 0 0 10px;
    }
    .stat__value {
      font-family: var(--mono);
      font-size: clamp(34px, 7vw, 52px);
      font-weight: 500;
      line-height: 1;
      letter-spacing: -0.01em;
      color: var(--ink);
      font-variant-numeric: tabular-nums;
    }

    /* Pages table */
    .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 15px;
    }
    thead th {
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-mute);
      text-align: left;
      padding: 0 14px 10px;
      border-bottom: 1px solid var(--rule);
      white-space: nowrap;
    }
    thead th.num { text-align: right; }
    tbody td {
      padding: 12px 14px;
      border-bottom: 1px solid var(--rule-soft);
      color: var(--ink-soft);
      vertical-align: baseline;
    }
    tbody tr:last-child td { border-bottom: none; }
    td.path {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--ink);
      word-break: break-all;
    }
    td.num {
      text-align: right;
      font-family: var(--mono);
      font-size: 14px;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
    td.empty {
      text-align: center;
      color: var(--ink-mute);
      font-style: italic;
      padding: 24px 14px;
    }

    /* Panels */
    .panels {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--gap-4);
    }
    @media (max-width: 640px) {
      .totals { grid-template-columns: 1fr; }
      .panels { grid-template-columns: 1fr; }
    }
    .panel {
      background: var(--surface);
      border: 1px solid var(--rule);
      border-radius: 4px;
      padding: 22px 24px;
    }
    .panel h3 {
      font-family: var(--sans);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 16px;
    }
    .list { margin: 0; padding: 0; list-style: none; }
    .list li {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 14px;
      padding: 9px 0;
      border-bottom: 1px solid var(--rule-soft);
    }
    .list li:last-child { border-bottom: none; }
    .list__name {
      font-size: 15px;
      color: var(--ink-soft);
      word-break: break-all;
    }
    .list__count {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--ink);
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
    .list__empty {
      color: var(--ink-mute);
      font-style: italic;
      font-size: 15px;
    }

    /* Device bars */
    .bar-row {
      display: block;
      padding: 9px 0;
      border-bottom: 1px solid var(--rule-soft);
    }
    .bar-row:last-child { border-bottom: none; }
    .bar-row__head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: 7px;
    }
    .bar-row__name {
      font-size: 15px;
      color: var(--ink-soft);
      text-transform: capitalize;
    }
    .bar-row__count {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--ink);
      font-variant-numeric: tabular-nums;
    }
    .bar-track {
      height: 6px;
      background: var(--rule-soft);
      border-radius: 3px;
      overflow: hidden;
    }
    .bar-fill {
      display: block;
      height: 100%;
      background: var(--accent-soft);
      border-radius: 3px;
    }

    /* Co-Intelligence content gaps */
    .cgap { padding-top: var(--gap-5); }
    .cgap:first-of-type { padding-top: 0; }
    .cgap__head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 14px;
      margin: 0 0 var(--gap-3);
    }
    .cgap__name {
      font-family: var(--sans);
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: capitalize;
      color: var(--ink);
    }
    .cgap__meta {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--ink-mute);
      font-variant-numeric: tabular-nums;
    }
    .list__count.tag { text-transform: none; color: var(--ink-mute); }

    /* Footer */
    footer {
      max-width: var(--content);
      margin: 0 auto;
      padding: 28px 28px 56px;
      border-top: 1px solid var(--rule);
      font-family: var(--sans);
      font-size: 12px;
      color: var(--ink-mute);
      line-height: 1.6;
    }
    @media (min-width: 700px) { footer { padding: 28px 40px 64px; } }
    footer p { margin: 0; }
  </style>
</head>
<body>

<header class="top">
  <span class="top__brand"><a href="/">OIATC</a> · Analytics</span>
  <span class="top__meta">{{ range.from }} — {{ range.to }}</span>
</header>

<main class="page">

  <section>
    <p class="eyebrow">Date range</p>
    <form method="get" class="range-form">
      <div class="field">
        <label for="from">From</label>
        <input type="date" id="from" name="from" value="{{ range.from }}">
      </div>
      <div class="field">
        <label for="to">To</label>
        <input type="date" id="to" name="to" value="{{ range.to }}">
      </div>
      <button type="submit">Apply</button>
    </form>
  </section>

  <section>
    <h2>Totals</h2>
    <div class="totals">
      <div class="stat">
        <p class="stat__label">Pageviews</p>
        <div class="stat__value">{{ report.totals.views }}</div>
      </div>
      <div class="stat">
        <p class="stat__label">Visitors</p>
        <div class="stat__value">{{ report.totals.visitors }}</div>
      </div>
    </div>
  </section>

  <section>
    <h2>Pages</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Path</th>
            <th class="num">Views</th>
            <th class="num">Visitors</th>
            <th class="num">Avg scroll</th>
            <th class="num">Avg time</th>
          </tr>
        </thead>
        <tbody>
          {% for row in report.pages %}
            <tr>
              <td class="path">{{ row.path }}</td>
              <td class="num">{{ row.views }}</td>
              <td class="num">{{ row.visitors }}</td>
              <td class="num">{{ row.avg_scroll }}%</td>
              <td class="num">{{ (row.avg_dwell_ms / 1000)|round(1) }}s</td>
            </tr>
          {% else %}
            <tr>
              <td class="empty" colspan="5">No data for this range yet.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <div class="panels">

      <div class="panel">
        <h3>Top referrers</h3>
        {% if report.referrers is empty %}
          <p class="list__empty">Direct / none recorded</p>
        {% else %}
          <ul class="list">
            {% for ref in report.referrers %}
              <li>
                <span class="list__name">{{ ref.host }}</span>
                <span class="list__count">{{ ref.count }}</span>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      <div class="panel">
        <h3>Devices</h3>
        {% if report.devices is empty %}
          <p class="list__empty">None recorded</p>
        {% else %}
          {% set device_max = 0 %}
          {% for d in report.devices %}
            {% if d.count > device_max %}{% set device_max = d.count %}{% endif %}
          {% endfor %}
          {% for d in report.devices %}
            <div class="bar-row">
              <div class="bar-row__head">
                <span class="bar-row__name">{{ d.device }}</span>
                <span class="bar-row__count">{{ d.count }}</span>
              </div>
              <div class="bar-track">
                <span class="bar-fill" style="width: {{ device_max > 0 ? (d.count / device_max * 100)|round(1) : 0 }}%"></span>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>

    </div>
  </section>

  {% if chat is defined and chat.communities is not empty %}
  <section>
    <h2>Co-Intelligence content gaps</h2>
    {% for slug, c in chat.communities %}
      <div class="cgap">
        <div class="cgap__head">
          <span class="cgap__name">{{ slug }}</span>
          <span class="cgap__meta">{{ c.totals.unanswered }} unanswered of {{ c.totals.total }} asked</span>
        </div>
        <div class="panels">
          <div class="panel">
            <h3>Most-asked topics</h3>
            {% if c.topics is empty %}
              <p class="list__empty">None recorded</p>
            {% else %}
              <ul class="list">
                {% for t in c.topics %}
                  <li>
                    <span class="list__name">{{ t.topic }}</span>
                    <span class="list__count">{{ t.count }}</span>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
          <div class="panel">
            <h3>Unanswered and no match</h3>
            {% if c.unanswered is empty %}
              <p class="list__empty">Nothing unanswered in this range</p>
            {% else %}
              <ul class="list">
                {% for u in c.unanswered %}
                  <li>
                    <span class="list__name">{{ u.question }}</span>
                    <span class="list__count tag">{{ u.outcome }} &middot; {{ u.topic }}</span>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </section>
  {% endif %}

</main>

<footer>
  <p>First-party, cookie-less analytics. No personal data stored; visitors are counted by a daily-rotating salted hash.</p>
</footer>

</body>
</html>
