{% block head_styles %}
  <style>
    /* Data-sovereignty explainer. Light editorial page on site tokens, with two
       custom "specimen" visuals (the CDN URL anatomy and the data map) rendered
       on the site's native dark statement surface so their original colours read.
       Namespaced .dsv-* so nothing collides with site.css. */
    .dsv-wrap { max-width: 800px; margin: 0 auto; padding: var(--gap-7) var(--gap-5) var(--gap-9); }
    .dsv-wrap h1 { font-family: var(--font-serif); font-size: clamp(28px, 4.2vw, 38px); line-height: 1.15; letter-spacing: -0.01em; font-weight: 400; margin: 0 0 var(--gap-3); }
    .dsv-wrap h2 { font-family: var(--font-serif); font-size: 22px; line-height: 1.25; font-weight: 600; letter-spacing: -0.01em; margin: var(--gap-7) 0 var(--gap-3); }
    .dsv-wrap p { margin: 0 0 var(--gap-3); }
    .dsv-wrap strong { color: var(--ink); font-weight: 600; }

    .dsv-byline { font-size: 14px; color: var(--ink-3); margin: var(--gap-4) 0 0; padding-top: var(--gap-4); border-top: 1px solid var(--rule); }

    .dsv-wrap ul { list-style: none; padding-left: 0; margin: 0 0 var(--gap-4); }
    .dsv-wrap li { position: relative; padding-left: 20px; margin: 0 0 10px; }
    .dsv-wrap li::before { content: ""; position: absolute; left: 3px; top: 12px; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }

    .dsv-hl { background: var(--accent-wash); color: var(--ink); padding: .03em .28em; border-radius: 4px; font-weight: 600; }
    .dsv-hlw { background: color-mix(in oklab, var(--accent) 22%, transparent); color: var(--ink); padding: .03em .28em; border-radius: 4px; font-weight: 600; }
    .dsv-pull { font-family: var(--font-serif); font-size: 21px; line-height: 1.4; color: var(--ink); font-weight: 500; border-left: 3px solid var(--accent); padding: 4px 0 4px 18px; margin: var(--gap-5) 0; }

    /* CDN URL anatomy — dark specimen. */
    .dsv-url { background: var(--statement-bg); color: var(--statement-fg); border-radius: var(--radius-md); padding: 18px; margin: var(--gap-4) 0; font-family: var(--font-mono); font-size: 14px; line-height: 2.1; word-break: break-all; }
    .dsv-url .host { color: #7fd0a8; }
    .dsv-url .red { background: color-mix(in oklab, var(--statement-fg) 16%, transparent); color: var(--statement-fg); border-radius: 4px; padding: 1px 7px; letter-spacing: .04em; }
