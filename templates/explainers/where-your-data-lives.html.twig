    .dsv-legend { margin: var(--gap-3) 0 0; font-size: 13.5px; color: var(--ink-3); line-height: 1.5; }
    .dsv-legend b { color: var(--ink-2); font-weight: 600; }

    /* Data map — dark specimen; the SVG is kept verbatim. */
    .dsv-map { background: var(--statement-bg); border-radius: var(--radius-md); padding: 14px 14px 6px; margin: var(--gap-4) 0; }
    .dsv-map svg { display: block; width: 100%; height: auto; }
    .dsv-mapcap { font-size: 13.5px; color: color-mix(in oklab, var(--statement-fg) 72%, transparent); line-height: 1.55; margin: 10px 4px 6px; }
    .dsv-mapcap b { color: var(--statement-fg); font-weight: 600; }
    .dsv-key { display: flex; flex-wrap: wrap; gap: 14px; margin: 4px 4px 8px; font-size: 13px; color: color-mix(in oklab, var(--statement-fg) 72%, transparent); }
    .dsv-key span { display: inline-flex; align-items: center; gap: 6px; }
    .dsv-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }

    .dsv-note { font-size: 14px; color: var(--ink-3); margin: var(--gap-6) 0 0; padding-top: var(--gap-4); border-top: 1px solid var(--rule); }
