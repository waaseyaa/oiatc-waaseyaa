              <span class="field__label">Note</span>
              <textarea class="field__input" rows="3" placeholder="What would you like to discuss with the council?"></textarea>
            </label>
          </div>
        </div>

        <div class="reveal" style="margin-bottom: var(--gap-7);">
          <h4>Badges &amp; tags</h4>
          <div style="display: flex; gap: var(--gap-3); flex-wrap: wrap;">
            <span class="badge">Draft</span>
            <span class="badge badge--accent">&sect; 1.1</span>
