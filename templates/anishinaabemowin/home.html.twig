{% block head_styles %}
  <style>
    /* The Anishinaabemowin project home. Built on the site's editorial tokens so
       it follows the light/dark toggle, in a WIDE frame (~1180px) with prose
       capped near 74ch. Everything namespaced .anm-* so nothing leaks into
       site.css. No images or audio. */
    .anm-wrap {
      --anm-max: 1180px;
      --anm-read: 74ch;
      max-width: var(--anm-max);
      margin: 0 auto;
      padding: var(--gap-7) var(--gap-5) var(--gap-9);
    }

    .anm-wrap h1 { font-family: var(--font-serif); font-weight: 400; font-size: clamp(34px, 6vw, 64px); line-height: 1.04; letter-spacing: -0.02em; margin: 0 0 var(--gap-3); }
    .anm-wrap h2 { font-family: var(--font-serif); font-weight: 600; font-size: clamp(22px, 2.6vw, 29px); line-height: 1.2; letter-spacing: -0.01em; margin: 0 0 var(--gap-3); }
    .anm-wrap p { margin: 0 0 var(--gap-4); }
    .anm-wrap strong { color: var(--ink); font-weight: 600; }

    .anm-num { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.08em; color: var(--accent-deep); font-weight: 500; }

    .anm-lede { font-family: var(--font-serif); font-size: clamp(18px, 1.7vw, 22px); line-height: 1.5; color: var(--ink-2); max-width: var(--anm-read); margin: 0 0 var(--gap-3); text-wrap: pretty; }
    .anm-updated { font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.04em; color: var(--accent-deep); margin: 0; }
    .anm-col { max-width: var(--anm-read); }
    .anm-col p { color: var(--ink); }

    /* Section scaffold */
    .anm-sec { margin: var(--gap-8) 0 0; scroll-margin-top: 80px; }
    .anm-sec__head { display: flex; align-items: baseline; gap: 14px; margin: 0 0 var(--gap-4); flex-wrap: wrap; }
    .anm-sec__head .anm-num { padding-top: 2px; }

    /* Jump nav */
    .anm-jump { display: flex; flex-wrap: wrap; gap: var(--gap-2); margin: var(--gap-6) 0 0; padding: var(--gap-3) 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .anm-jump a { font-family: var(--font-sans); font-size: 13px; font-weight: 500; color: var(--ink-2); text-decoration: none; border: 1px solid var(--rule); border-radius: 999px; padding: 5px 13px; white-space: nowrap; transition: border-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease); }
    .anm-jump a:hover { color: var(--accent-deep); border-color: var(--accent-soft); }

    /* Stat band */
    .anm-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--rule); border: 1px solid var(--rule); border-radius: var(--radius-lg); overflow: hidden; margin: var(--gap-5) 0 0; }
    @media (max-width: 720px) { .anm-stats { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 400px) { .anm-stats { grid-template-columns: 1fr; } }
    .anm-stat { background: var(--paper); padding: 18px 20px; }
    .anm-stat b { display: block; font-family: var(--font-sans); font-size: clamp(26px, 3vw, 32px); font-weight: 700; letter-spacing: -0.015em; color: var(--ink); line-height: 1.05; }
    .anm-stat span { display: block; font-size: 12.5px; color: var(--ink-3); line-height: 1.45; margin-top: 6px; }

    /* Pull quote */
    .anm-pull { font-family: var(--font-serif); font-size: clamp(23px, 3.4vw, 36px); line-height: 1.26; font-weight: 400; font-style: italic; color: var(--accent-deep); text-align: center; max-width: 22em; margin: var(--gap-7) auto; padding: var(--gap-6) 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); text-wrap: balance; }

    /* Card grids (two-up desktop, stacked mobile) */
    .anm-cards { display: grid; gap: var(--gap-3); margin: var(--gap-4) 0 0; }
    @media (min-width: 720px) { .anm-cards { grid-template-columns: repeat(2, 1fr); } }
    .anm-card { background: var(--paper-2); border: 1px solid var(--rule); border-left: 3px solid var(--accent-soft); border-radius: var(--radius-md); padding: 18px 20px; }
    .anm-card h3 { font-family: var(--font-serif); font-size: 19px; font-weight: 600; margin: 0 0 8px; color: var(--ink); display: flex; align-items: baseline; gap: 10px; }
