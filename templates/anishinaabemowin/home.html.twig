    .anm-card p { margin: 0; color: var(--ink-2); font-size: 14.5px; line-height: 1.6; }
    .anm-card p + p { margin-top: 10px; }
    .anm-card a { color: var(--accent-deep); }
    .anm-card--live { border-left-color: var(--accent); }

    /* Bulleted capability / source list */
    .anm-list { list-style: none; padding-left: 0; margin: var(--gap-4) 0 0; max-width: 96ch; }
    .anm-list li { position: relative; padding-left: 22px; margin: 0 0 14px; line-height: 1.6; color: var(--ink); }
    .anm-list li::before { content: ""; position: absolute; left: 3px; top: 11px; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
    .anm-list li strong { color: var(--ink); }

    /* Settled vs being decided, two columns */
    .anm-twocol { display: grid; gap: var(--gap-3); margin: var(--gap-4) 0 0; }
    @media (min-width: 760px) { .anm-twocol { grid-template-columns: repeat(2, 1fr); } }
    .anm-panel { background: var(--paper-2); border: 1px solid var(--rule); border-radius: var(--radius-md); padding: 18px 20px; }
    .anm-panel h3 { font-family: var(--font-sans); font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent-deep); margin: 0 0 12px; }
    .anm-panel ul { list-style: none; margin: 0; padding: 0; }
    .anm-panel li { position: relative; padding-left: 18px; margin: 0 0 10px; font-size: 14.5px; line-height: 1.55; color: var(--ink-2); }
    .anm-panel li:last-child { margin-bottom: 0; }
    .anm-panel li::before { content: ""; position: absolute; left: 0; top: 9px; width: 5px; height: 5px; border-radius: 50%; background: var(--accent-soft); }

    /* Progress log: left date rail, easy to append */
    .anm-log { margin: var(--gap-4) 0 0; max-width: 100ch; }
    .anm-log__entry { display: grid; grid-template-columns: 168px 1fr; gap: var(--gap-4); padding: 16px 0; border-top: 1px solid var(--rule); }
    .anm-log__entry:last-child { border-bottom: 1px solid var(--rule); }
    @media (max-width: 620px) { .anm-log__entry { grid-template-columns: 1fr; gap: 4px; } }
    .anm-log__date { font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.02em; color: var(--accent-deep); line-height: 1.5; }
    .anm-log__body { font-size: 15px; line-height: 1.65; color: var(--ink); }

    /* Take part CTA panel */
    .anm-cta { background: var(--accent-wash); border: 1px solid var(--accent-soft); border-left: 4px solid var(--accent); border-radius: var(--radius-lg); padding: 24px 26px; margin: var(--gap-4) 0 0; max-width: 96ch; }
    .anm-cta p { color: var(--ink); font-size: 15.5px; line-height: 1.6; margin: 0 0 var(--gap-4); max-width: 80ch; }
    .anm-cta__btn { display: inline-flex; align-items: center; gap: 9px; font-family: var(--font-sans); font-size: 15px; font-weight: 600; color: var(--paper); background: var(--accent-deep); border-radius: 999px; padding: 11px 22px; text-decoration: none; transition: filter var(--dur-fast) var(--ease); }
    .anm-cta__btn:hover { filter: brightness(1.08); }
    .anm-cta__addr { display: block; margin-top: 12px; font-family: var(--font-mono); font-size: 13px; color: var(--ink-2); }
    .anm-cta__addr a { color: var(--accent-deep); }

    /* Sources + byline */
    .anm-sources { font-family: var(--font-sans); font-size: 14px; line-height: 1.55; list-style: none; padding: 0; margin: var(--gap-4) 0 0; max-width: 100ch; }
    .anm-sources li { padding: 13px 0; border-bottom: 1px solid var(--rule); color: var(--ink-2); }
    .anm-sources li:last-child { border-bottom: 0; }
    .anm-sources a { color: var(--accent-deep); word-break: break-word; }

    .anm-byline { font-size: 13.5px; color: var(--ink-3); line-height: 1.6; margin: var(--gap-7) 0 0; padding-top: var(--gap-4); border-top: 1px solid var(--rule); max-width: 96ch; }
