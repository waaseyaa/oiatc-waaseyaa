{
    "name": "waaseyaa/oiatc-waaseyaa",
    "description": "Ontario Indigenous AI & Technology Council public site",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.4",
        "waaseyaa/access": "^0.1",
        "waaseyaa/api": "^0.1",
        "waaseyaa/cache": "^0.1",
        "waaseyaa/cli": "^0.1",
        "waaseyaa/config": "^0.1",
        "waaseyaa/database-legacy": "^0.1",
        "waaseyaa/entity": "^0.1",
        "waaseyaa/entity-storage": "^0.1",
        "waaseyaa/field": "^0.1",
        "waaseyaa/foundation": "^0.1",
        "waaseyaa/media": "^0.1",
        "waaseyaa/menu": "^0.1",
        "waaseyaa/node": "^0.1",
        "waaseyaa/path": "^0.1",
        "waaseyaa/routing": "^0.1",
        "waaseyaa/taxonomy": "^0.1",
        "waaseyaa/user": "^0.1",
        "waaseyaa/workflows": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "App\\Provider\\SiteServiceProvider"
            ]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "audit-site": "./bin/waaseyaa-audit-site",
        "post-create-project-cmd": [
            "chmod +x bin/waaseyaa bin/waaseyaa-version bin/verify-deploy-rsync bin/waaseyaa-audit-site",
            "php bin/post-create-setup.php"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
