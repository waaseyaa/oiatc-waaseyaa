{
    "name": "waaseyaa/oiatc-waaseyaa",
    "description": "Ontario Indigenous AI & Technology Council public site",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.5",
        "symfony/dotenv": "^8.0",
        "waaseyaa/anokii": "^0.1.0-alpha.11",
        "waaseyaa/framework": "0.1.0-alpha.250"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "config": {
        "optimize-autoloader": true,
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": true
        }
    },
    "scripts": {
        "audit-site": "./bin/waaseyaa-audit-site",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse --memory-limit=1G",
        "regen-lock": "@composer update 'waaseyaa/*' --no-plugins --no-install --no-scripts",
        "post-create-project-cmd": [
            "chmod +x bin/waaseyaa bin/waaseyaa-version bin/verify-deploy-rsync bin/waaseyaa-audit-site",
            "php bin/post-create-setup.php"
        ]
    },
    "extra": {
        "merge-plugin": {
            "include": [
                "composer.local.json"
            ],
            "prepend-repositories": true
        },
        "waaseyaa": {
            "providers": [
                "Anokii\\Provider\\CoIntelligenceServiceProvider",
                "App\\Provider\\AppServiceProvider",
                "App\\Provider\\IngestDocsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
