{% extends 'base.html.twig' %}

{% block title %}Grants & Funding | OIATC{% endblock %}

{% block content %}
  <section class="page-header">
    <div class="eyebrow">Capital and readiness</div>
    <h1>Grants &amp; Funding</h1>
    <p>OIATC is aligning its first-stage platform, governance, training, research, and infrastructure work against programs that fit Indigenous-led institution building in Ontario.</p>
    <p><strong>Last reviewed:</strong> April 2, 2026</p>
  </section>

  <section class="section">
    <div class="funding-table">
      <table>
        <thead>
          <tr>
            <th>Program</th>
            <th>Fit for OIATC</th>
            <th>Status posture</th>
            <th>Official source</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>FedDev Ontario</td>
            <td>Platform development, commercialization pathways, and regional workforce buildout in southern Ontario.</td>
            <td>Current research target for platform and scaling conversations.</td>
            <td><a href="https://feddev-ontario.canada.ca/en/funding-and-support">Official FedDev funding page</a></td>
          </tr>
          <tr>
            <td>ISC Indigenous business supports</td>
            <td>Training pathways, Indigenous-led pilots, regional initiatives, and business growth supports.</td>
            <td>Current research target for community-facing implementation work.</td>
            <td><a href="https://www.sac-isc.gc.ca/eng/1100100033057/1610797769658">Official ISC economic development and business page</a></td>
          </tr>
          <tr>
            <td>Ontario Indigenous Community Capital Grants Program</td>
            <td>Capital planning for community spaces, digital hubs, archives, and related infrastructure.</td>
            <td>Current research target for capital and space planning.</td>
            <td><a href="https://forms.mgcs.gov.on.ca/en/dataset/006-0247">Official Ontario ICCGP guide</a></td>
          </tr>
          <tr>
            <td>Ontario Trillium Foundation</td>
            <td>Community programming, youth pathways, workshops, and scaling proven local work.</td>
            <td>Current research target for programming and engagement.</td>
            <td><a href="https://www.otf.ca/our-grants">Official OTF grants page</a></td>
          </tr>
          <tr>
            <td>SSHRC opportunities</td>
            <td>Research, policy, governance documentation, and partnership development.</td>
            <td>Watched opportunity until specific calls are verified for launch outreach.</td>
            <td><a href="https://www.sshrc-crsh.gc.ca/funding-financement/index-eng.aspx">Official SSHRC funding page</a></td>
          </tr>
          <tr>
            <td>NSERC Alliance Grants</td>
            <td>Technical R&amp;D with academic partners around safe, explainable, and community-accountable systems.</td>
            <td>Watched opportunity pending partner-specific research fit.</td>
            <td><a href="https://www.nserc-crsng.gc.ca/Innovate-Innover/AllianceRoadmap-FeuilledeRouteAlliance/Index_eng.asp">Official NSERC Alliance page</a></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="section grid-2">
    <article class="card">
      <h3>How OIATC is framing applications</h3>
      <ul class="list">
        <li>Institutional governance and data sovereignty</li>
        <li>Platform development through Waaseyaa and Minoo</li>
        <li>Community training and operator pathways</li>
        <li>Capital planning for durable Indigenous digital infrastructure</li>
      </ul>
    </article>
    <article class="card">
      <h3>Important note</h3>
      <p>These opportunities are research targets, not guarantees. OIATC verifies official program pages before funder-facing outreach and removes or downgrades any item that cannot be confirmed.</p>
    </article>
  </section>
{% endblock %}
